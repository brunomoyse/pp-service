# Production environment template for PocketPair backend.
# Copy to .env.production and fill in real values from your secret manager.
# DO NOT commit the filled-in file.

# --- Database ---
PG_DB=pocketpair
PG_USER=pocketpair
PG_PASSWORD=__set_me__
DATABASE_MAX_CONNECTIONS=30

# --- Auth (REQUIRED) ---
# Generate with: openssl rand -base64 32
JWT_SECRET=__set_me__
JWT_EXPIRATION_HOURS=24

# --- OAuth (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Public base URL the OAuth provider redirects back to (https in prod).
REDIRECT_BASE_URL=https://pocketpair.be/api

# --- HTTP / security ---
# Comma-separated origins allowed by CORS (the manager + landing + app webviews).
ALLOWED_ORIGINS=https://pocketpair.be,https://app.pocketpair.be
# Schema introspection stays off in production (the app also defaults it to false).
GQL_INTROSPECTION=false
RUST_LOG=info

# --- Backups ---
BACKUP_RETENTION_DAYS=14
BACKUP_INTERVAL_SECONDS=21600
